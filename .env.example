# CSOJ 环境配置文件示例
# 复制此文件为 .env 并根据实际情况修改配置

# ==================== 数据库配置 ====================
# ⚠️ 生产环境必须修改以下密码！不能使用默认值！
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=oj_db
MYSQL_USER=oj_user
# ⚠️ 必填，不能为空
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_PORT=3306

# ==================== Redis 配置 ====================
REDIS_PORT=6379
# ⚠️ 必填，不能为空
REDIS_PASSWORD=your_redis_password_here

# ==================== RabbitMQ 配置 ====================
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
# ⚠️ 必填，不能为空，生产环境请使用强密码
RABBITMQ_PASSWORD=your_rabbitmq_password_here

# ==================== 后端服务配置 ====================
BACKEND_PORT=8121
SPRING_PROFILES_ACTIVE=prod

# ⚠️ 沙箱服务密钥（生产环境必须修改为复杂密钥，否则服务拒绝启动！）
CODE_SANDBOX_SECRET=your-secret-key-here

# 文件上传路径（可选，默认为 ./uploads）
# FILE_UPLOAD_PATH=/app/uploads

# ==================== 代码沙箱配置 ====================
SANDBOX_PORT=8090

# Docker 容器池配置（根据服务器资源调整）
# 小型部署（<100人）: 10/2
# 中型部署（100-500人）: 20/5
# 大型部署（>500人）: 50/10
DOCKER_POOL_MAX_SIZE=20
DOCKER_POOL_MIN_SIZE=5

# ==================== 并发配置 ====================
# 根据服务器 CPU 核心数和内存调整
# 判题线程池配置
ASYNC_JUDGE_CORE_POOL_SIZE=10
ASYNC_JUDGE_MAX_POOL_SIZE=20
ASYNC_JUDGE_QUEUE_CAPACITY=200

# Tomcat 线程池配置
TOMCAT_MAX_THREADS=200
TOMCAT_MAX_CONNECTIONS=10000
TOMCAT_ACCEPT_COUNT=100

# ==================== 前端配置（可选）====================
FRONTEND_PORT=80

# ==================== 部署规模建议 ====================
# 小型规模（50-100人并发）:
#   DOCKER_POOL_MAX_SIZE=10
#   ASYNC_JUDGE_MAX_POOL_SIZE=10
#   ASYNC_JUDGE_QUEUE_CAPACITY=100
#   TOMCAT_MAX_THREADS=100
#
# 中型规模（100-300人并发）:
#   DOCKER_POOL_MAX_SIZE=20
#   ASYNC_JUDGE_MAX_POOL_SIZE=20
#   ASYNC_JUDGE_QUEUE_CAPACITY=200
#   TOMCAT_MAX_THREADS=200
#
# 大型规模（300-500人并发）:
#   DOCKER_POOL_MAX_SIZE=50
#   ASYNC_JUDGE_MAX_POOL_SIZE=50
#   ASYNC_JUDGE_QUEUE_CAPACITY=500
#   TOMCAT_MAX_THREADS=500
#
# 超大型规模（>500人并发）:
#   建议使用 Kubernetes 部署，支持水平扩展
