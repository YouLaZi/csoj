# CSOJ 后端 Docker 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ============================================
# MySQL 配置
# ============================================
MYSQL_ROOT_PASSWORD=csoj123456
MYSQL_PORT=3306

# ============================================
# Redis 配置
# ============================================
REDIS_PORT=6379

# ============================================
# Elasticsearch 配置
# ============================================
ES_PORT=9200

# ============================================
# 应用配置
# ============================================
APP_PORT=8121

# ============================================
# CORS 配置
# 生产环境请修改为实际域名
# ============================================
CORS_ALLOWED_ORIGINS=*

# ============================================
# 监控服务配置（可选）
# ============================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
