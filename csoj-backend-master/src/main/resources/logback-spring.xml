<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds" debug="false">
    <!-- 定义日志文件的存储地址 -->
    <property name="LOG_HOME" value="${LOG_PATH:-./logs}" />
    <property name="APP_NAME" value="csoj-backend" />

    <!-- 控制台输出 -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 按照每天生成日志文件 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 错误日志单独记录 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 警告日志单独记录 -->
    <appender name="WARN_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}-warn.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>WARN</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-warn.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 判题服务日志单独记录 -->
    <appender name="JUDGE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/judge.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/judge.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 代码沙箱日志单独记录 -->
    <appender name="SANDBOX_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/sandbox.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/sandbox.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- SQL 执行日志单独记录 -->
    <appender name="SQL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/sql.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/sql.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>15</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 业务日志单独记录 -->
    <appender name="BUSINESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/business.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/business.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 异步日志配置 - 提高日志写入性能 -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>512</queueSize>
        <appender-ref ref="FILE"/>
    </appender>

    <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>512</queueSize>
        <appender-ref ref="ERROR_FILE"/>
    </appender>

    <appender name="ASYNC_WARN" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>512</queueSize>
        <appender-ref ref="WARN_FILE"/>
    </appender>

    <!-- ============================== -->
    <!-- 组件日志配置 -->
    <!-- ============================== -->

    <!-- 判题相关的logger -->
    <logger name="com.oj.cs.judge" level="INFO" additivity="false">
        <appender-ref ref="JUDGE_FILE" />
        <appender-ref ref="STDOUT" />
    </logger>

    <!-- 代码沙箱相关的logger -->
    <logger name="com.oj.cs.judge.codesandbox" level="INFO" additivity="false">
        <appender-ref ref="SANDBOX_FILE" />
        <appender-ref ref="STDOUT" />
    </logger>

    <!-- SQL 日志 -->
    <logger name="com.oj.cs.mapper" level="DEBUG" additivity="false">
        <appender-ref ref="SQL_FILE"/>
        <appender-ref ref="STDOUT"/>
    </logger>
    <logger name="com.baomidou.mybatisplus" level="DEBUG" additivity="false">
        <appender-ref ref="SQL_FILE"/>
        <appender-ref ref="STDOUT"/>
    </logger>
    <logger name="org.apache.ibatis" level="DEBUG" additivity="false">
        <appender-ref ref="SQL_FILE"/>
    </logger>

    <!-- 业务日志（Service层） -->
    <logger name="com.oj.cs.service" level="INFO" additivity="false">
        <appender-ref ref="BUSINESS_FILE"/>
        <appender-ref ref="STDOUT"/>
    </logger>

    <!-- ============================== -->
    <!-- 开发环境配置 -->
    <!-- ============================== -->
    <springProfile name="dev">
        <!-- Root 日志级别 -->
        <root level="INFO">
            <appender-ref ref="STDOUT"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>

        <!-- 应用核心日志 -->
        <logger name="com.oj.cs" level="DEBUG"/>

        <!-- MyBatis Plus SQL 日志（开发环境详细输出）-->
        <logger name="com.baomidou.mybatisplus" level="DEBUG"/>
        <logger name="com.baomidou.mybatisplus.core.MybatisConfiguration" level="DEBUG"/>
        <logger name="org.apache.ibatis" level="DEBUG"/>

        <!-- Spring 框架日志 -->
        <logger name="org.springframework" level="INFO"/>
        <logger name="org.springframework.web" level="DEBUG"/>
        <logger name="org.springframework.boot" level="INFO"/>
        <logger name="org.springframework.context" level="INFO"/>

        <!-- Redis 日志 -->
        <logger name="org.springframework.data.redis" level="INFO"/>

        <!-- Elasticsearch 日志 -->
        <logger name="org.elasticsearch.client" level="INFO"/>

        <!-- 第三方库日志 -->
        <logger name="com.github.xiaoymin" level="INFO"/>
        <logger name="cn.hutool" level="INFO"/>
        <logger name="com.alibaba" level="INFO"/>
        <logger name="com.squareup.okhttp" level="INFO"/>
    </springProfile>

    <!-- ============================== -->
    <!-- 测试环境配置 -->
    <!-- ============================== -->
    <springProfile name="test">
        <!-- Root 日志级别 -->
        <root level="INFO">
            <appender-ref ref="STDOUT"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_WARN"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>

        <!-- 应用核心日志 -->
        <logger name="com.oj.cs" level="INFO"/>

        <!-- MyBatis Plus SQL 日志（测试环境输出） -->
        <logger name="com.baomidou.mybatisplus" level="DEBUG"/>
        <logger name="com.baomidou.mybatisplus.core.MybatisConfiguration" level="DEBUG"/>
        <logger name="org.apache.ibatis" level="DEBUG"/>

        <!-- Spring 框架日志 -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.springframework.web" level="INFO"/>

        <!-- 第三方库日志 -->
        <logger name="org.elasticsearch.client" level="WARN"/>
        <logger name="com.github.xiaoymin" level="WARN"/>
        <logger name="cn.hutool" level="INFO"/>
        <logger name="com.alibaba" level="INFO"/>
    </springProfile>

    <!-- ============================== -->
    <!-- 生产环境配置 -->
    <!-- ============================== -->
    <springProfile name="prod">
        <!-- Root 日志级别 -->
        <root level="INFO">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_WARN"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>

        <!-- 应用核心日志 -->
        <logger name="com.oj.cs" level="INFO"/>

        <!-- MyBatis Plus SQL 日志（生产环境关闭或只输出警告） -->
        <logger name="com.baomidou.mybatisplus" level="WARN"/>
        <logger name="com.baomidou.mybatisplus.core.MybatisConfiguration" level="WARN"/>
        <logger name="org.apache.ibatis" level="WARN"/>

        <!-- Spring 框架日志 -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.springframework.web" level="WARN"/>
        <logger name="org.springframework.boot" level="WARN"/>
        <logger name="org.springframework.context" level="WARN"/>

        <!-- Redis 日志 -->
        <logger name="org.springframework.data.redis" level="WARN"/>

        <!-- Elasticsearch 日志 -->
        <logger name="org.elasticsearch.client" level="ERROR"/>

        <!-- 第三方库日志 -->
        <logger name="com.github.xiaoymin" level="ERROR"/>
        <logger name="cn.hutool" level="WARN"/>
        <logger name="com.alibaba" level="WARN"/>
        <logger name="com.squareup.okhttp" level="WARN"/>
        <logger name="org.apache" level="WARN"/>
        <logger name="com.sun" level="WARN"/>
    </springProfile>

    <!-- ============================== -->
    <!-- 默认配置（未指定环境时） -->
    <!-- ============================== -->
    <springProfile name="!dev &amp; !test &amp; !prod">
        <root level="INFO">
            <appender-ref ref="STDOUT"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>
        <logger name="com.oj.cs" level="INFO"/>
        <logger name="com.baomidou.mybatisplus" level="DEBUG"/>
        <logger name="org.apache.ibatis" level="DEBUG"/>
    </springProfile>
</configuration>
